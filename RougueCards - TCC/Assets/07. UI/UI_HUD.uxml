                <engine:VisualElement name="ButtonContainer02" style="flex-grow: 1; flex-direction: column; align-items: center; justify-content: flex-start; align-self: center; width: 100%; height: 100%; margin-top: 12px;">
                    <engine:Button text="FLIP" name="flip" class="cardButton" style="align-items: auto;" />
                    <engine:Button text="PICK UP" name="pickUp" class="cardButton" />
