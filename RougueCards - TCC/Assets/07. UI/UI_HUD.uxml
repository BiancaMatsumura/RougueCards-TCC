                    <engine:VisualElement name="back" class="backCard" style="flex-grow: 1; background-color: rgb(255, 255, 255); border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; position: absolute; max-width: 250px; max-height: 350px; width: 100%; height: 100%; display: flex; background-image: url(&quot;project://database/Assets/05.%20Sprites/teste/PNG/Default/Panel/panel-001.png?fileID=2800000&amp;guid=85ca0b7bdb5f4ab4692b430edd59e31c&amp;type=3#panel-001&quot;); -unity-background-image-tint-color: rgba(5, 0, 255, 0.55); -unity-slice-scale: 1px; padding-bottom: 30px; justify-content: space-around; align-items: center;">
