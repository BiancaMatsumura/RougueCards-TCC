                    <engine:VisualElement name="front" class="frontCard" style="flex-grow: 1; background-color: rgb(255, 255, 255); border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; position: absolute; max-width: 250px; max-height: 350px; align-items: center; width: 100%; height: 100%; -unity-background-image-tint-color: rgba(255, 0, 0, 0.5); background-repeat: no-repeat no-repeat; background-image: url(&quot;project://database/Assets/05.%20Sprites/teste/PNG/Default/Panel/panel-001.png?fileID=2800000&amp;guid=85ca0b7bdb5f4ab4692b430edd59e31c&amp;type=3#panel-001&quot;); background-position-x: left 0; background-position-y: top 0; -unity-slice-scale: 1px; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; -unity-background-scale-mode: stretch-to-fill; background-size: 100% 100%; justify-content: flex-end; align-content: flex-end; padding-bottom: 30px; display: flex;">
