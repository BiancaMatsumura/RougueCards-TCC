<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:VisualElement name="telaInicial" enabled="true" style="flex-grow: 1; flex-direction: row; align-items: auto; justify-content: flex-end; align-self: stretch; position: absolute; width: 1920px; height: 1080px;" />
    <engine:VisualElement name="container" picking-mode="Ignore" style="flex-grow: 1; height: 1080px; width: 1920px; flex-direction: row;">
        <engine:VisualElement name="Player01" class="player01" style="flex-grow: 1; flex-direction: row; background-color: rgba(255, 0, 0, 0.08); -unity-background-image-tint-color: rgb(255, 255, 255); -unity-text-outline-width: 0; margin-top: 0; margin-left: 0; margin-bottom: 0; margin-right: 0; -unity-text-outline-color: rgb(0, 0, 0); border-top-width: 1.5px; border-right-width: 1.5px; border-bottom-width: 1.5px; border-left-width: 1.5px; border-left-color: rgba(0, 0, 0, 0); border-right-color: rgb(0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0);" />
        <engine:VisualElement name="Player02" class="player02" style="flex-grow: 1; border-top-width: 1.5px; border-right-width: 1.5px; border-bottom-width: 1.5px; border-left-width: 1.5px; border-left-color: rgb(0, 0, 0); background-color: rgba(87, 98, 253, 0.06);" />
    </engine:VisualElement>
</engine:UXML>
